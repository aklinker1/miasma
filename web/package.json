    "autoprefixer": "^10.2.6",
    "eslint": "^7.30.0",
    "eslint-plugin-only-warn": "^1.0.2",
    "eslint-plugin-vue": "^7.12.1",
    "husky": "^7.0.0",
    "postcss": "^8.3.5",
    "prettier": "^2.3.2",
    "pretty-quick": "^3.1.1",
    "tailwindcss": "^2.2.4",
